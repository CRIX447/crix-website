rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Any signed-in user can submit a report, only admins can read/manage them
    match /reports/{reportId} {
      allow create: if request.auth != null
                    && request.resource.data.reporterUid == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }

    // Any signed-in user can read bans (so the game can check if they are banned)
    // Only admins can create/delete bans
    match /bans/{banId} {
      allow read: if request.auth != null;
      allow create, delete: if isAdmin();
    }

    // Config (admin IPs etc) - any signed-in user can read, only admins can write
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Admin = one of the whitelisted email addresses
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'crixgamingvr@gmail.com' ||
        request.auth.token.email == 'ihatetomatos259@hotmail.com'
      );
    }
  }
}
